# Copy this file to `.env` in the **same directory** (repo root: "Modular Code").
# Do **not** commit `.env` — it holds secrets.
#
# Load before starting the API, for example:
#   set -a && source .env && set +a && npm run api
# Or use `scripts/brainstorm-api.sh`, which sources `.env` automatically if present.

# --- Update map (DeepSeek, OpenAI-compatible API) ---
# Create a key at https://platform.deepseek.com/
# `deepseek-chat` is DeepSeek-V3.2 in non-thinking mode (see DeepSeek API changelog).
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Set to 1 to stub overlay labels without calling the API (UI / CI wiring).
# UPDATE_MAP_DRY_RUN=0

# Set to 1 to stub orchestrator (Slice B) without calling the LLM.
# ORCHESTRATE_DRY_RUN=0

# Set to 1 to stub developer AI execution (Slice C) without calling the LLM.
# EXECUTE_DRY_RUN=0

# Set to 1 to stub the work session flow (POST /go, GET /status/:id) without a real AI.
# WORK_DRY_RUN=0

# Live pytest (`tests/test_update_map_live.py`) requires DEEPSEEK_API_KEY above.
# Air-gapped only: SKIP_LIVE_LLM=1
# See docs/product-vision/LLM-TESTING.md

# --- AgentAPI + Aider (AI coding agent) ---
# Aider uses DEEPSEEK_API_KEY above (set AGENT_MODEL to override the model).
# AgentAPI binary: https://github.com/coder/agentapi/releases
# Aider: pip install aider-chat
#
# AGENT_CMD=aider                        # default; set to 'opencode' to use OpenCode instead
# AGENT_MODEL=deepseek/deepseek-chat     # default DeepSeek V3 via DeepSeek API
# AGENTAPI_CMD=agentapi                  # path to agentapi binary if not on PATH

# --- Brainstorm API (existing) ---
BRAINSTORM_PUBLIC_DIR=
BRAINSTORM_GOLDEN_REPO=
