{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "execution-graph": {
      "type": "local",
      "command": [
        "uv",
        "--directory", "packages/raw-indexer",
        "run", "--extra", "mcp",
        "python", "-m", "raw_indexer.mcp_server"
      ],
      "environment": {
        "BRAINSTORM_PUBLIC_DIR": "{env:BRAINSTORM_PUBLIC_DIR}",
        "BRAINSTORM_GOLDEN_REPO": "{env:BRAINSTORM_GOLDEN_REPO}"
      }
    }
  }
}
