{
  "name": "modular-code",
  "private": true,
  "description": "Monorepo root — npm scripts delegate to poc-brainstorm-ui",
  "scripts": {
    "dev": "npm run dev --prefix poc-brainstorm-ui",
    "dev:api": "npm run dev:api --prefix poc-brainstorm-ui",
    "dev:studio": "npm run index:golden && concurrently -k -n api,ui -c blue,magenta \"npm run api\" \"sleep 2 && npm run dev:api\"",
    "api": "bash scripts/brainstorm-api.sh",
    "build": "npm run build --prefix poc-brainstorm-ui",
    "lint": "npm run lint --prefix poc-brainstorm-ui",
    "preview": "npm run preview --prefix poc-brainstorm-ui",
    "index:golden": "npm run index:golden --prefix poc-brainstorm-ui",
    "check:orphans": "npm run check:orphans --prefix poc-brainstorm-ui"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
